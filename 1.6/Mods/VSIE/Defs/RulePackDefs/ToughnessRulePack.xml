<Defs>
  <RulePackDef>
    <defName>VSIE_Teaching_Toughness</defName>
    <include>
      <li>VSIE_TeachingUtility</li>
    </include>
    <rulePack>
      <rulesStrings>
        <li>r_logentry->[INITIATOR_nameDef] and [RECIPIENT_nameDef] [talkedabout] [ToughnessTopic].</li>
		<li>r_logentry->[INITIATOR_nameDef] [talkedabout] [ToughnessTopic] with [RECIPIENT_nameDef].</li>
		<li>r_logentry(p=0.8)->[INITIATOR_nameDef] [commentedabout] [ToughnessTopic] to [RECIPIENT_nameDef].</li>

		<li>talkedabout(p=4)->chatted about</li>
		<li>talkedabout->shared a word about</li>
		<li>talkedabout->spoke about</li>
		<li>talkedabout->gabbed about</li>
		<li>talkedabout->talked about</li>
		<li>talkedabout->joked about</li>
		<li>talkedabout->quipped about</li>

		<li>commentedabout->said something about</li>
		<li>commentedabout->said a word about</li>
		<li>commentedabout->made a comment about</li>
		<li>commentedabout->commented about</li>
		<li>commentedabout->told a joke about</li>
		
      </rulesStrings>
	  <rulesFiles>
		    <li>ToughnessTopic->Words/TeachingWords/ToughnessSkill</li>
      </rulesFiles>
    </rulePack>
  </RulePackDef>
</Defs>